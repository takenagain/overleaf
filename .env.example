# Copy this file to `.env` and update values for your environment.
# Overleaf/ShareLaTeX runtime configuration consumed by docker compose.

# Host data directory override used by docker-compose bind mounts.
# Default mount root is `${HOME}/sharelatex` when this is unset.
# SHARELATEX_DATA_ROOT_DIR=sharelatex

# Core application settings
OVERLEAF_APP_NAME=Overleaf Community Edition
OVERLEAF_MONGO_URL=mongodb://mongo/sharelatex

# Redis host is read from two config paths in Overleaf.
OVERLEAF_REDIS_HOST=redis
REDIS_HOST=redis

# Feature toggles
ENABLED_LINKED_FILE_TYPES=project_file,project_output_file
ENABLE_CONVERSIONS=true
EMAIL_CONFIRMATION_DISABLED=true

# Reverse proxy and HTTPS settings
# Use the actual public URL where users access Overleaf.
OVERLEAF_SITE_URL=https://overleaf.example.com
# Set all trusted proxy ranges that can forward client IP headers.
OVERLEAF_TRUSTED_PROXY_IPS=loopback,172.19.0.0/16
OVERLEAF_BEHIND_PROXY=true
OVERLEAF_SECURE_COOKIE=true

# Branding and admin contact
OVERLEAF_NAV_TITLE=Overleaf Community Edition
OVERLEAF_ADMIN_EMAIL=support@example.com
OVERLEAF_EMAIL_FROM_ADDRESS=no-reply@example.com

# Optional branding
# OVERLEAF_HEADER_IMAGE_URL=https://assets.example.com/overleaf-logo.png
# OVERLEAF_LEFT_FOOTER='[{"text":"Visit <a href=\"https://docs.example.com\">Documentation</a>"}]'
# OVERLEAF_RIGHT_FOOTER='[{"text":"Managed by Example IT"}]'

# Optional SMTP delivery
# OVERLEAF_EMAIL_SMTP_HOST=smtp.example.com
# OVERLEAF_EMAIL_SMTP_PORT=587
# OVERLEAF_EMAIL_SMTP_SECURE=false
# OVERLEAF_EMAIL_SMTP_USER=overleaf
# OVERLEAF_EMAIL_SMTP_PASS=change-me
# OVERLEAF_EMAIL_SMTP_TLS_REJECT_UNAUTH=true
# OVERLEAF_EMAIL_SMTP_IGNORE_TLS=false
# OVERLEAF_EMAIL_SMTP_NAME=127.0.0.1
# OVERLEAF_EMAIL_SMTP_LOGGER=false
# OVERLEAF_CUSTOM_EMAIL_FOOTER=This system is run by Example IT

# Optional AWS SES delivery
# OVERLEAF_EMAIL_AWS_SES_ACCESS_KEY_ID=AKIA...
# OVERLEAF_EMAIL_AWS_SES_SECRET_KEY=replace-me

# Optional maintenance task
# ENABLE_CRON_RESOURCE_DELETION=true

# Server Pro only: keep disabled in Community Edition to avoid compile failures.
# SANDBOXED_COMPILES=true
# SANDBOXED_COMPILES_HOST_DIR_COMPILES=/home/user/sharelatex_data/data/compiles
# SANDBOXED_COMPILES_HOST_DIR_OUTPUT=/home/user/sharelatex_data/data/output
# DOCKER_RUNNER=true
# SANDBOXED_COMPILES_SIBLING_CONTAINERS=true

# Optional LDAP settings
# OVERLEAF_LDAP_URL=ldap://ldap:389
# OVERLEAF_LDAP_SEARCH_BASE=ou=people,dc=example,dc=com
# OVERLEAF_LDAP_SEARCH_FILTER=(uid={{username}})
# OVERLEAF_LDAP_BIND_DN=cn=admin,dc=example,dc=com
# OVERLEAF_LDAP_BIND_CREDENTIALS=replace-me
# OVERLEAF_LDAP_EMAIL_ATT=mail
# OVERLEAF_LDAP_NAME_ATT=cn
# OVERLEAF_LDAP_LAST_NAME_ATT=sn
# OVERLEAF_LDAP_UPDATE_USER_DETAILS_ON_LOGIN=true

# Optional templates and proxy learning
# OVERLEAF_TEMPLATES_USER_ID=578773160210479700917ee5
# OVERLEAF_NEW_PROJECT_TEMPLATE_LINKS='[{"name":"All Templates","url":"/templates/all"}]'
# OVERLEAF_PROXY_LEARN=true
